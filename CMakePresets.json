{
  "version": 3,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Dev (tests + compile_commands)",
      "description": "Local development: tests enabled, compile_commands.json generated",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "EDN_CPP_BUILD_TESTS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ci",
      "displayName": "CI",
      "description": "Continuous integration: tests enabled, Release build",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "EDN_CPP_BUILD_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release",
      "displayName": "Release (install)",
      "description": "Release build without tests; used for install/packaging",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "EDN_CPP_BUILD_TESTS": "OFF",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "sanitize",
      "displayName": "Sanitize (ASan + UBSan)",
      "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer — gate 2 of CI",
      "binaryDir": "${sourceDir}/build-san",
      "cacheVariables": {
        "EDN_CPP_BUILD_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "NOMOS_SANITIZE": "address,undefined"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev",      "configurePreset": "dev" },
    { "name": "ci",       "configurePreset": "ci" },
    { "name": "sanitize", "configurePreset": "sanitize" },
    { "name": "release",  "configurePreset": "release" }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "output": { "outputOnFailure": true }
    }
  ]
}
